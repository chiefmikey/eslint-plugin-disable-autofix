{
  "compilerOptions": {
    "lib": ["es2022"],
    "moduleResolution": "Node",
    "module": "ESNext",
    "target": "es2022",
    "sourceMap": false,
    "allowJs": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": false,
    "noImplicitAny": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "outDir": "./dist",
    "types": ["jest"]
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "jest.config.*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
