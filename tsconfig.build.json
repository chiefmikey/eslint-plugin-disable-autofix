{
  "compilerOptions": {
    "lib": [
      "es6"
    ],
    "moduleResolution": "Node",
    "module": "CommonJS",
    "target": "es6",
    "sourceMap": false,
    "allowJs": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": false,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "noEmit": false,
    "noImplicitAny": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "outDir": "./dist/cjs",
    "paths": {
      "./*.ts": [
        "./*"
      ]
    },
    "declarationMap": true,
    "declarationDir": "./dist/types",
    "rootDir": "./src",
    "composite": true,
    "types": ["node", "eslint"],
    "typeRoots": ["./node_modules/@types", "./types"]
  },
  "files": [
    "./src/index.ts"
  ],
  "include": [
    "src/**/*.ts",
    "index.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
