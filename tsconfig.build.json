{
  "compilerOptions": {
    "lib": ["es2022"],
    "moduleResolution": "Node",
    "module": "CommonJS",
    "target": "es2022",
    "rootDir": "./src",
    "outDir": "./dist",
    "sourceMap": false,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "noEmit": false,
    "noImplicitAny": true,
    "removeComments": true,
    "preserveConstEnums": true
  },
  "include": ["./src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
